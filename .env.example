# Copie este arquivo para ".env" e preencha com a connection string real do seu banco PostgreSQL.
#
# Onde conseguir essa string:
#  - Neon (neon.tech): crie um projeto gratuito, vá em "Connection string" e copie a versão "Pooled connection"
#  - Supabase / Railway: têm telas equivalentes de "Connection string" / "Database URL"
#
# Formato esperado:
# DATABASE_URL="postgresql://usuario:senha@host:5432/nome_do_banco?sslmode=require"

DATABASE_URL=""
